    preco: 150,
    precoAntigo: 29.90,
    imagem: "img/gallery/sem-estoq.jpg",
    hover: "img/gallery/sem-estoq-hover.jpg",
    categoria: "promocao",
    desconto: "50% OFF",
    estoque: 0
  },
  {
    nome: "Produto Teste",
    preco: 15,
    imagem: "img/gallery/sem-estoq.jpg",
    hover: "img/gallery/sem-estoq-hover.jpg",
